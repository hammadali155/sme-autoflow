# .streamlit/secrets.toml.example
# Do not commit your actual secrets.toml file!

# Used by the backend to generate the workflows
GEMINI_API_KEY = "your_google_gemini_api_key_here"

# Used by the frontend to point to the backend (Heroku, Render, etc)
# API_BASE_URL = "https://your-fastapi-backend.herokuapp.com"

# Used to optionally push generated workflows straight to n8n
N8N_URL = "https://your-n8n-instance.com"
N8N_API_KEY = "your_n8n_api_key_here"
